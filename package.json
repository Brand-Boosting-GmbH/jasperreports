{
  "name": "jasperreports",
  "version": "0.3.0",
  "description": "Lightweight, zero-Java JasperReports JRXML to PDF renderer for Cloudflare Workers, Node.js, Deno and browsers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^1.6.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "jasperreports",
    "jasper",
    "jrxml",
    "pdf",
    "pdf-lib",
    "report",
    "reporting",
    "cloudflare-workers",
    "serverless",
    "certificate",
    "document"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brand-Boosting-GmbH/jasperreports.git"
  },
  "bugs": {
    "url": "https://github.com/Brand-Boosting-GmbH/jasperreports/issues"
  },
  "homepage": "https://github.com/Brand-Boosting-GmbH/jasperreports#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
